datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// MODÈLE UTILISATEUR (FUSIONNÉ ET ADAPTÉ AU MODE SAAS)
// ============================================================================

model User {
  id                            String                   @id @default(uuid()) // Version originale d'Open SaaS (String)
  email                         String?                  @unique
  username                      String?                  @unique
  createdAt                     DateTime                 @default(now())
  isAdmin                       Boolean                  @default(false)
  sendEmail                     Boolean                  @default(false)
  
  // === CHAMPS COMPLÉMENTAIRES CXSAT AJOUTÉS (Optionnels pour éviter les erreurs de compilation) ===
  nom                           String?                  @default("")
  prenom                        String?                  @default("")
  telephone                     String?                  @default("")
  role                          String?                  @default("AGENT") // DIRECTION, QUALITE, CHEF_AGENCE, AGENT
  actif                         Boolean                  @default(true)
  id_agence                     Int?                     // Nullable pour l'onboarding SaaS (Siège créé après)
  agence                        Agence?                  @relation(fields: [id_agence], references: [id])

  // Dénormalisé volontairement : permet de scoper DIRECTION/QUALITE à leur
  // propre entreprise (tenant) sans avoir à recharger la relation agence.entreprise
  // dans chaque query/action. Toujours tenu synchronisé avec agence.id_entreprise
  // (voir src/server/middleware/rowLevelSecurity.ts).
  id_entreprise                 Int?
  entreprise                    Entreprise?              @relation(fields: [id_entreprise], references: [id])
  
  affectations                  AffectationGuichet[]
  alertes                       Alerte[]
  taches                        TacheCorrective[]
  reponses                      Reponse[]                @relation("AgentResponses")
  historiquesTaches             TacheCorrectiveHistorique[] @relation("HistoriqueAuteur")

  // === RELATIONS PAR DÉFAUT D'OPEN SAAS ===
  files                         File[]
}

// ============================================================================
// STRUCTURE ORGANISATIONNELLE (CXSAT)
// ============================================================================

model Entreprise {
  id                  Int               @id @default(autoincrement())
  nom_entreprise      String
  date_creation_compte DateTime         @default(now())
  
  agences             Agence[]
  utilisateurs        User[]
  criteres            Critere[]
  services            Service[]
  brandConfig         BrandConfig?
}

model BrandConfig {
  id                   Int        @id @default(autoincrement())
  id_entreprise        Int        @unique
  entreprise           Entreprise @relation(fields: [id_entreprise], references: [id], onDelete: Cascade)

  // --- NOM DE LA PLATEFORME ---
  platform_name        String     @default("CXSAT")
  platform_description String     @default("Plateforme de pilotage de la satisfaction client")

  // --- LOGOS & FAVICON ---
  logo_url             String?
  logo_dark_url        String?
  favicon_url          String?

  // --- DESIGN SYSTEM COMPLET (Couleurs en HSL) ---
  color_background     String     @default("40 20% 98.5%")
  color_foreground     String     @default("0 0% 3.9%")
  
  color_card           String     @default("40 20% 99%")
  color_card_foreground String    @default("0 0% 3.9%")
  color_popover        String     @default("0 0% 100%")
  color_popover_foreground String @default("0 0% 3.9%")
  
  color_primary        String     @default("210 100% 13%")
  color_primary_foreground String  @default("0 0% 98%")
  color_secondary      String     @default("32 100% 37%")
  color_secondary_foreground String @default("0 0% 9%")
  color_accent         String     @default("33 74% 62%")
  color_accent_foreground String  @default("0 0% 98%")
  
  color_muted          String     @default("0 0% 96.1%")
  color_muted_foreground String    @default("0 0% 38%")
  color_destructive    String     @default("0 84.2% 60.2%")
  color_destructive_foreground String @default("0 0% 98%")
  color_success        String     @default("141 71% 48%")
  color_success_foreground String  @default("0 0% 98%")
  color_warning        String     @default("36 100% 50%")
  color_warning_foreground String  @default("0 0% 98%")

  color_border         String     @default("0 0% 89.8%")
  color_input          String     @default("0 0% 89.8%")
  color_ring           String     @default("0 0% 3.9%")

  // --- STYLE ET EFFETS ---
  border_radius        String     @default("0.5rem")
  shadow_style         String     @default("DEFAULT") // NONE, DEFAULT, SHARP, GLOW
  font_family          String     @default("Satoshi")
  font_url             String?

  // --- TEXTES ET SLOGANS PERSONNALISÉS (FORMULAIRES PUBLIC / AFFICHES) ---
  form_title           String     @default("Votre avis compte !")
  form_subtitle        String     @default("Notez-nous en 10 secondes apres votre passage")
  form_thank_you       String     @default("Merci pour votre avis !")
  qr_slogan            String     @default("Scannez ce QR Code")
  ussd_help_text       String     @default("Pas de connexion internet ?")
  hide_cxsat_branding  Boolean    @default(false)

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}


model Agence {
  id                  Int               @id @default(autoincrement())
  nom_agence          String
  commune             String
  adresse             String?
  heure_ouverture     String            @default("08:00")
  heure_fermeture     String            @default("17:00")
  jours_ouvres        String            @default("1,2,3,4,5,6")
  
  id_entreprise       Int
  entreprise          Entreprise        @relation(fields: [id_entreprise], references: [id], onDelete: Cascade)
  
  utilisateurs        User[]
  guichets            Guichet[]
  objectifs           Objectif[]
  reponses            Reponse[]
  statistiques        StatistiquesMensuelles[]
  agencesCriteres     AgenceCritere[]
}

model Guichet {
  id                  Int               @id @default(autoincrement())
  nom_guichet         String
  type_guichet        String?
  actif               Boolean           @default(true)
  
  id_agence           Int
  agence              Agence            @relation(fields: [id_agence], references: [id], onDelete: Cascade)
  
  affectations        AffectationGuichet[]
  reponses            Reponse[]
  alertes             Alerte[]
  statistiques        StatistiquesMensuelles[]
  services            Service[]
}

model AffectationGuichet {
  id                  Int               @id @default(autoincrement())
  date_affectation    DateTime          @db.Date
  heure_debut         String
  heure_fin           String
  
  id_guichet          Int
  guichet             Guichet           @relation(fields: [id_guichet], references: [id], onDelete: Cascade)
  
  id_agent            String            // Adapté à l'identifiant String de User
  agent               User              @relation(fields: [id_agent], references: [id], onDelete: Cascade)
}

// ============================================================================
// CONTEXTE D'ÉVALUATION (CXSAT)
// ============================================================================

model Service {
  id                  Int               @id @default(autoincrement())
  libelle_service     String

  // NULL = service "socle" fourni par la plateforme (visible par toutes les
  // entreprises, ex. seed initial). Une valeur = service propre à une
  // entreprise, invisible aux autres. Voir Critere pour le même principe.
  id_entreprise       Int?
  entreprise          Entreprise?       @relation(fields: [id_entreprise], references: [id], onDelete: Cascade)

  reponses            Reponse[]
  statistiques        StatistiquesMensuelles[]
  guichets            Guichet[]
  // Voir CritereService : relation explicite avec ordre d'affichage.
  criteresServices    CritereService[]
}

model Critere {
  id                  Int               @id @default(autoincrement())
  libelle_critere     String
  description         String?
  
  // === NOUVEAUX CHAMPS DYNAMIQUES ===
  type_reponse        String            @default("SMILEY") // SMILEY, OUI_NON, QCM, TEXTE
  options_reponse     String?           // Choix séparés par des virgules pour le QCM

  // NULL = critère "socle" fourni par la plateforme (visible par toutes les
  // entreprises, ex. les 3 critères FD X50-167 créés au seed). Une valeur =
  // critère créé par une entreprise via createCritere, invisible aux autres
  // entreprises (isolation demandée : chaque DIRECTION ne voit que le
  // catalogue commun + les critères de sa propre entreprise).
  id_entreprise       Int?
  entreprise          Entreprise?       @relation(fields: [id_entreprise], references: [id], onDelete: Cascade)

  objectifs           Objectif[]
  reponses            Reponse[]
  statistiques        StatistiquesMensuelles[]
  agencesCriteres     AgenceCritere[]
  // Relation explicite (et non plus many-to-many implicite) pour pouvoir
  // stocker un ordre d'affichage par opération : c'est ce qui permet de
  // glisser-déposer les questions pour les réordonner ou les déplacer
  // d'une opération à l'autre (voir CritereService plus bas).
  criteresServices    CritereService[]
}

// Table de jonction explicite Critère <-> Opération (Service). Remplace
// l'ancienne relation many-to-many implicite (_CritereToService) pour
// pouvoir porter un champ `ordre` par paire (critère, opération) : c'est ce
// qui permet à l'UI de type "todo" de réordonner les questions au sein
// d'une opération et de les déplacer d'une opération à une autre par
// glisser-déposer.
model CritereService {
  id          Int      @id @default(autoincrement())

  id_critere  Int
  critere     Critere  @relation(fields: [id_critere], references: [id], onDelete: Cascade)

  id_service  Int
  service     Service  @relation(fields: [id_service], references: [id], onDelete: Cascade)

  // Position d'affichage de la question au sein de cette opération
  // (0 = première question affichée). Modifié par reorderCriteresService.
  ordre       Int      @default(0)

  @@unique([id_critere, id_service])
  @@index([id_service, ordre])
}

model AgenceCritere {
  id_agence  Int
  agence     Agence  @relation(fields: [id_agence], references: [id], onDelete: Cascade)
  id_critere Int
  critere    Critere @relation(fields: [id_critere], references: [id], onDelete: Cascade)

  @@id([id_agence, id_critere])
}

model Objectif {
  id                  Int               @id @default(autoincrement())
  valeur_cible        Decimal           @db.Decimal(5, 2)
  date_debut          DateTime          @db.Date
  date_fin            DateTime          @db.Date
  
  id_critere          Int
  critere             Critere           @relation(fields: [id_critere], references: [id], onDelete: Cascade)
  
  id_agence           Int
  agence              Agence            @relation(fields: [id_agence], references: [id], onDelete: Cascade)
}

model Canal {
  id                  Int               @id @default(autoincrement())
  type_canal          String            // QR_WEB, USSD, IVR_VOCAL
  langue_utilisee     String
  
  reponses            Reponse[]
}

// ============================================================================
// FLUX TRANSACTIONNEL (CXSAT)
// ============================================================================

model Reponse {
  id                  BigInt            @id @default(autoincrement())
  date_reponse        DateTime          @default(now())
  score_brut          Int
  audio_url           String?
  commentaire_texte   String?
  id_soumission       String?
  
  id_critere          Int
  critere             Critere           @relation(fields: [id_critere], references: [id])
  
  id_canal            Int
  canal               Canal             @relation(fields: [id_canal], references: [id])
  
  id_agence           Int
  agence              Agence            @relation(fields: [id_agence], references: [id], onDelete: Cascade)
  
  id_guichet          Int
  guichet             Guichet           @relation(fields: [id_guichet], references: [id])
  
  id_service          Int?
  service             Service?          @relation(fields: [id_service], references: [id])
  
  id_agent            String?           // Adapté à l'identifiant String de User
  agent               User?             @relation("AgentResponses", fields: [id_agent], references: [id], onDelete: SetNull)
  
  alertes             Alerte[]
}

model Alerte {
  id                  BigInt            @id @default(autoincrement())
  message             String
  statut_alerte       String            @default("NOUVELLE")
  type_alerte         String            // NOTE_CRITIQUE, SILENCE_EVALUATION
  date_creation       DateTime          @default(now())
  date_traitement     DateTime?
  
  id_reponse          BigInt?
  reponse             Reponse?          @relation(fields: [id_reponse], references: [id], onDelete: Cascade)
  
  id_destinataire     String            // Adapté à l'identifiant String de User
  destinataire        User              @relation(fields: [id_destinataire], references: [id], onDelete: Cascade)
  
  id_guichet_concerne Int?
  guichet             Guichet?  @relation(fields: [id_guichet_concerne], references: [id], onDelete: SetNull)

  taches              TacheCorrective[]
}

model TacheCorrective {
  id                  BigInt            @id @default(autoincrement())
  titre               String
  description         String?
  statut_tache        String            @default("A_FAIRE")
  date_creation       DateTime          @default(now())
  date_echeance       DateTime
  date_cloture        DateTime?
  
  id_alerte           BigInt
  alerte              Alerte            @relation(fields: [id_alerte], references: [id], onDelete: Cascade)
  
  id_responsable      String            // Adapté à l'identifiant String de User
  responsable         User              @relation(fields: [id_responsable], references: [id])

  historique          TacheCorrectiveHistorique[]
}

// ============================================================================
// HISTORIQUE & AUDIT DES TÂCHES CORRECTIVES (Conformité ARTCI)
// Enregistre chaque changement de statut avec horodatage, auteur et
// commentaire optionnel — permet de reconstituer l'historique complet en
// cas de litige ou d'audit qualité.
// ============================================================================

model TacheCorrectiveHistorique {
  id              BigInt          @id @default(autoincrement())
  date_action     DateTime        @default(now())
  ancien_statut   String
  nouveau_statut  String
  commentaire     String?

  id_tache        BigInt
  tache           TacheCorrective @relation(fields: [id_tache], references: [id], onDelete: Cascade)

  id_auteur       String
  auteur          User            @relation("HistoriqueAuteur", fields: [id_auteur], references: [id])

  @@index([id_tache, date_action])
}

// ============================================================================
// ANTI-REJEU DES VOTES (CXSAT — Conformité ARTCI)
// ============================================================================

model VoteAntiRejeu {
  id           BigInt   @id @default(autoincrement())
  hachage_tel  String   @unique // SHA-256(sel + telephone) — anonymisé
  date_vote    DateTime @default(now())

  @@index([date_vote])
}

model StatistiquesMensuelles {
  id                  BigInt            @id @default(autoincrement())
  annee               Int
  mois                Int
  nombre_reponses     Int               @default(0)
  score_moyen         Decimal           @db.Decimal(5, 2)
  niveau_conformite   String            @default("Informelle")
  
  id_agence           Int
  agence              Agence            @relation(fields: [id_agence], references: [id], onDelete: Cascade)
  
  id_guichet          Int?
  guichet             Guichet?          @relation(fields: [id_guichet], references: [id], onDelete: SetNull)
  
  id_service          Int?
  service             Service?          @relation(fields: [id_service], references: [id], onDelete: SetNull)
  
  id_critere          Int
  critere             Critere           @relation(fields: [id_critere], references: [id], onDelete: Cascade)
}

// ============================================================================
// TABLES TECHNIQUES ET ANALYTICS REQUISES PAR LE TEMPLATE OPEN SAAS
// ============================================================================

model File {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   // Adapté à l'identifiant String de User
  name      String
  s3Key     String   // Nom du champ d'origine requis par Open SaaS
  type      String   // Ajout du champ de type MIME pour le module d'upload
  url       String?
}

model Logs {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  message      String
  level        String
}